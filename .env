# arXiv API (бесплатен, без ключа)
ARXIV_BASE_URL=https://export.arxiv.org/api/query

# PubMed API (если нужен)
# Получить ключ: https://www.ncbi.nlm.nih.gov/books/NBK25497/
PUBMED_API_KEY=your_pubmed_api_key_here

# CrossRef API (бесплатен, без ключа)
CROSSREF_BASE_URL=https://api.crossref.org/works

# Кэширование (время в миллисекундах)
CACHE_DURATION=86400000
